{
  "name": "carecompass",
  "version": "1.0.0",
  "private": true,
  "description": "Patient-centered healthcare management platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:mobile\"",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:mobile": "npm run start --workspace=apps/mobile",
    "build": "npm run build --workspaces",
    "build:api": "npm run build --workspace=apps/api",
    "test": "npm run test --workspaces",
    "test:api": "npm run test --workspace=apps/api",
    "lint": "npm run lint --workspaces",
    "db:migrate": "npm run prisma:migrate --workspace=apps/api",
    "db:generate": "npm run prisma:generate --workspace=apps/api",
    "db:seed": "npm run prisma:seed --workspace=apps/api"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "typescript": "^5.3.0"
  }
}
